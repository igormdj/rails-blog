    font-weight: bold;
    margin-right: 10px;
  }

  .button-link:hover {
    background-color: #27ae60;
  }

  .back-link {
    display: inline-block;
    background-color: #3498db;
    color: white;
    padding: 10px 15px;
    border-radius: 5px;
    text-decoration: none;
    font-weight: bold;
  }

  .back-link:hover {
    background-color: #2980b9;
  }

  hr {
    margin: 30px 0;
