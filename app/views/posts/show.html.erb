    margin-bottom: 30px;
    border: 1px solid #e9ecef;
  }

  .form-group {
    margin-bottom: 15px;
  }

  .form-group label {
    display: block;
    margin-bottom: 8px;
    font-weight: bold;
    color: #2c3e50;
  }

  .comment-textarea {
