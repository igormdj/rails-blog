<div class="post-detail-container">
  <h1><%= @post.title %></h1>

    <%# NOVO: EXIBIR TAGS %>
  <% if @post.tags.any? %>
    <div class="post-tags">
      <strong>🏷️ Tags:</strong>
      <% @post.tags.each do |tag| %>
        <%= link_to tag.name, tag_path(tag), class: "tag" %>
      <% end %>
    </div>
  <% end %>
    
  <div class="post-content">
    <p><%= @post.content %></p>
    <small>Postado em: <%= @post.created_at.strftime("%d/%m/%Y %H:%M") %></small>
  </div>

  <div class="post-actions">
    <% if user_signed_in? && @post.user == current_user %>
      <%= link_to "Editar Post", edit_post_path(@post), class: "button-link" %>
    <% end %>
    <%= link_to "Voltar para a lista", root_path, class: "back-link" %>
  </div>

  <hr>

  <div class="comments-section">
    <h2>Comentários (<%= @post.comments.count %>)</h2>

    <% if user_signed_in? %>
      <div class="new-comment">
        <h3>Adicionar comentário</h3>
        <%= form_with(model: [@post, Comment.new], local: true, class: "comment-form") do |f| %>
          <div class="form-group">
            <%= f.label :content, "Seu comentário" %>
            <%= f.text_area :content, rows: 4, placeholder: "Escreva seu comentário...", required: true, class: "comment-textarea" %>
          </div>
          <%= f.submit "Comentar", class: "submit-button" %>
        <% end %>
      </div>
    <% else %>
      <div class="login-prompt">
        <p><%= link_to "Faça login", new_user_session_path %> para comentar.</p>
      </div>
    <% end %>

    <div class="comments-list">
      <% if @post.comments.any? %>
        <% @post.comments.order(created_at: :desc).each do |comment| %>
          <div class="comment">
            <div class="comment-header">
              <div class="comment-user-info">
                <%# Renderizando o avatar %>
                <%= render "shared/avatar", user: comment.user, size: 32 %>
                
                <strong><%= comment.user.email %></strong>
                <small><%= time_ago_in_words(comment.created_at) %> atrás</small>
                <% if comment.created_at != comment.updated_at %>
                  <small>(editado)</small>
                <% end %>
              </div>
              
              <% if user_signed_in? && comment.user == current_user %>
                <div class="comment-actions">
                  <%= link_to "Editar", edit_post_comment_path(@post, comment), class: "edit-link" %>
                  <%= link_to "Excluir", post_comment_path(@post, comment), 
                              data: { turbo_method: :delete, turbo_confirm: "Tem certeza?" },
                              class: "delete-link" %>
                </div>
              <% end %>
            </div>
            <div class="comment-content">
              <%= simple_format(comment.content) %>
            </div>
          </div>
        <% end %>
      <% else %>
        <p class="no-comments">Nenhum comentário ainda. Seja o primeiro a comentar!</p>
      <% end %>
    </div>
  </div>
</div>

<style>
