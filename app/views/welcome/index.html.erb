<div class="container">
  <h1>Bem-vindo ao Meu App Rails</h1>

  <%# FORMULÁRIO DE BUSCA %>
  <div class="search-container">
    <%= form_tag root_path, method: :get, class: "search-form" do %>
      <div class="search-input-group">
        <%= text_field_tag :search, params[:search], 
            placeholder: "Buscar posts por título ou conteúdo...", 
            class: "search-input" %>
        <%= submit_tag "🔍 Buscar", class: "search-button" %>
        
        <% if params[:search].present? %>
          <%= link_to "✖ Limpar", root_path, class: "clear-search" %>
        <% end %>
      </div>
    <% end %>
  </div>

  <% if params[:search].present? %>
    <div class="pagination-info" style="background-color: #e8f4fd;">
      <strong>Resultados para:</strong> "<%= params[:search] %>" 
      (<%= @posts.total_count %> posts encontrados)
    </div>
  <% end %>

  <h2>📝 Minhas Postagens</h2>

  <%# INFORMAÇÃO DA PAGINAÇÃO %>
  <div class="pagination-info">
    <strong>
      📄 Mostrando página <%= @posts.current_page %> de <%= @posts.total_pages %> 
      | 📊 Total: <%= @posts.total_count %> posts
    </strong>
  </div>

  <%# CONTROLES DE QUANTIDADE %>
  <div class="posts-controls">
    <div class="per-page-selector">
      <strong>📑 Posts por página:</strong>
      <select onchange="window.location.href='<%= root_path %>?per_page='+this.value + (document.querySelector('input[name=\"search\"]') ? '&search=' + encodeURIComponent(document.querySelector('input[name=\"search\"]').value) : '')">
        <option value="5" <%= 'selected' if params[:per_page].to_i == 5 %>>5 posts</option>
        <option value="10" <%= 'selected' if params[:per_page].to_i == 10 %>>10 posts</option>
        <option value="15" <%= 'selected' if params[:per_page].to_i == 15 %>>15 posts</option>
        <option value="20" <%= 'selected' if params[:per_page].to_i == 20 %>>20 posts</option>
        <option value="50" <%= 'selected' if params[:per_page].to_i == 50 %>>50 posts</option>
      </select>
    </div>
  </div>

  <%# LISTA DE POSTS CENTRALIZADA %>
  <div class="posts-list">
    <% if @posts.any? %>
      <% @posts.each do |post| %>
        <div class="post-card">
          <h3><%= post.title %></h3>

            <%# NOVO: EXIBIR TAGS RESUMIDAS %>
  <% if post.tags.any? %>
    <div class="post-tags" style="margin: 10px 0;">
      <% post.tags.first(3).each do |tag| %>
        <span class="tag-badge"><%= tag.name %></span>
      <% end %>
      <% if post.tags.count > 3 %>
        <span class="tag-badge">+<%= post.tags.count - 3 %></span>
      <% end %>
    </div>
  <% end %>
  
          <p><%= post.content.truncate(200) %></p>
          
          <div class="post-meta">
            👤 Publicado por: <strong><%= post.user.email %></strong> | 
            📅 Criado em: <%= formatar_data_hora(post.created_at) %>
          </div>
          
          <div class="post-actions">
            <%= link_to "👁️ Ver Post Completo", post_path(post), class: "button-link" %>
            
            <% if user_signed_in? && post.user == current_user %>
              <%= link_to "✏️ Editar", edit_post_path(post), class: "button-link", style: "background-color: #f39c12;" %> 
              <%= link_to "🗑️ Excluir", post_path(post), 
                          data: { turbo_method: :delete, turbo_confirm: "Tem certeza?" }, 
                          class: "button-link", 
                          style: "background-color: #e74c3c;" %>
            <% end %>
          </div>
        </div>
      <% end %>
      
      <%# LINKS DE PAGINAÇÃO %>
      <%= paginate @posts %>
      
    <% else %>
      <div style="text-align: center; padding: 50px; background-color: #f8f9fa; border-radius: 8px;">
        <p>😕 Nenhum post encontrado. Que tal criar o primeiro?</p>
      </div>
    <% end %>
  </div>

  <br>

  <div style="text-align: center; margin-top: 20px;">
    <% if user_signed_in? %>
      <%= link_to "✨ Criar Novo Post", new_post_path, class: "button-link", style: "background-color: #2ecc71; padding: 12px 25px; font-size: 1.1em;" %>
    <% else %>
      <p>🔐 <%= link_to "Faça login", new_user_session_path %> para criar um post.</p>
    <% end %>
  </div>
</div>